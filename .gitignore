# --- 系统文件 (操作系统自动生成的) ---
.DS_Store
Thumbs.db

# --- 依赖包 (体积大，不需要上传) ---
node_modules/
venv/
__pycache__/

# --- 编译/构建产物 ---
dist/
build/
*.exe
*.dll
*.so

# --- 日志文件 ---
*.log
npm-debug.log*

# --- IDE 配置 (个人的编辑器设置) ---
.vscode/
.idea/

# --- 敏感配置 (绝对不能上传！！！) ---
.env
config.js
secrets.yml

# --- 例外规则 ---
# 忽略所有 markdown 文件
*.md
# 但是 README.md 必须保留
!README.md