# ==========================
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/
.env/

# uv (Python manager)
# 注意：uv.lock 必须提交，所以不要写在这里
.uv/

# ==========================
# 2. Node.js & Frontend
# ==========================
node_modules/

# Package Locks
# 我们只用 pnpm，所以忽略其他包管理器的锁文件，防止混乱
package-lock.json
yarn.lock
# 注意：pnpm-lock.yaml 必须提交，所以不要写在这里！

# Next.js
.next/
out/
.npm
.eslintcache
.turbo/
build/
dist/
*.tsbuildinfo

# Storybook
.storybook/out/
lobe-ui/

# ==========================
# 3. Environment & Secrets (重要!)
# ==========================
.env
.env.local
.env.*.local
.env.production
.env.development
# 排除 Docker Compose 的环境文件
.env.docker

# ==========================
# 4. Database & Migrations
# ==========================
*.sqlite3
*.db
*.db-journal

# !!! 关键修正：保留 alembic/versions/ 
# 这里只忽略 alembic 产生的缓存，不要忽略 versions 文件夹
__pycache__/

# Docker 挂载的持久化数据 (防止把几个G的数据库传上去)
data/postgres_data/
data/redis_data/
# 如果你有不想提交的测试数据放在 data 根目录，保留下面这行
data/

