# ==========================
.trae/
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ==========================
# 6. Docker & Deployment
# ==========================
.dockerignore
Dockerfile.local
# 如果你的 .pem 证书是部署用的，千万别传
*.pem
*.pub

# ==========================
# 7. Local Runtime (项目特有)
# ==========================
# Windows 一键启动脚本下载的临时环境，绝对不能传
.runtime/
.node_runtime/
uv.exe
node.exe
npm.cmd
npx.cmd

