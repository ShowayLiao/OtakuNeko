# 模式开关
DEPLOY_MODE=cloud

# 基础配置
# ==============================
PROJECT_NAME=OtakuNeko
API_V1_STR=/api/v1
DEBUG=true
# 这里的 Key 保持您原本测试用的即可
OPENAI_API_KEY=test-secret-key-for-jwt-debugging

# JWT 安全密钥（生产环境必须设置，生成方式：python -c "import secrets; print(secrets.token_urlsafe(32))"）
JWT_SECRET_KEY=dev-jwt-secret-change-in-production

# ==============================
# 模式 A: Local 配置
# ==============================
SQLITE_FILE=./test.db

# ==============================
# 模式 B: Cloud 配置
# (只有当 DEPLOY_MODE=cloud 时，下面这些才会被用到)
# ==============================
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=otaku
POSTGRES_PASSWORD=password
POSTGRES_DB=otakuneko

# 云端模式下的 Redis
REDIS_URL=redis://localhost:6379/0

# qBittorrent 配置
ENABLE_QB_PROXY=false
QB_HOST=http://qbittorrent:8080
QB_USERNAME=admin
QB_PASSWORD=your_password